//@version=6
// -----------------------------------------------------------------------------
// Nombre: Separador de Períodos Avanzado (v6 - Solución por Timestamp)
// Descripción: Este indicador utiliza una lógica de dibujo basada en timestamps
// para colocar los separadores mensuales. Esto soluciona definitivamente el
// problema de desplazamiento en mercados que cierran los fines de semana (Forex)
// al dibujar la línea en su coordenada de tiempo exacta.
// -----------------------------------------------------------------------------
indicator('Separador de Períodos Avanzado', shorttitle = 'Separador Pro', overlay = true, max_lines_count = 500)

// --- GRUPO DE CONFIGURACIÓN GENERAL Y TOGGLES ---
group_general = '1. Configuración General'
gmt_zona_horaria = input.string('GMT-4', 'Zona Horaria para Medianoche (ej. GMT-4, UTC)', group = group_general)
show_domingos = input.bool(false, 'Mostrar Líneas de Domingo', group = group_general, inline = 'dom')
show_mensual_en_intradia = input.bool(false, 'Mostrar Sep. Mensual/Trimestral en Intradía', group = group_general, inline = 'mq_intradia')
show_solo_trimestres = input.bool(false, 'Mostrar solo Líneas Trimestrales', group = group_general, inline = 'mq_intradia')

// --- GRUPO DE CONFIGURACIÓN DE LÍNEAS DIARIAS ---
group_diario = '2. Estilo Líneas Diarias'
// Lunes
color_lunes = input.color(color.new(#ffffff, 80), 'Lunes', group = group_diario, inline = 'lunes')
grosor_lunes = input.int(1, '', minval = 1, maxval = 5, group = group_diario, inline = 'lunes')
estilo_lunes_str = input.string('Solid', '', options = ['Solid', 'Dashed', 'Dotted'], group = group_diario, inline = 'lunes')
// Otros Días
color_otros = input.color(color.new(#000000, 0), 'Otros Días', group = group_diario, inline = 'otros')
grosor_otros = input.int(1, '', minval = 1, maxval = 5, group = group_diario, inline = 'otros')
estilo_otros_str = input.string('Dotted', '', options = ['Solid', 'Dashed', 'Dotted'], group = group_diario, inline = 'lunes')

// --- GRUPO DE CONFIGURACIÓN DE LÍNEAS MENSUALES Y TRIMESTRALES ---
group_mensual = '3. Estilo Líneas Mensuales y Trimestrales'
// Mensual
color_mensual = input.color(color.new(color.blue, 70), 'Mensual', group = group_mensual, inline = 'mensual')
grosor_mensual = input.int(1, '', minval = 1, maxval = 5, group = group_mensual, inline = 'mensual')
estilo_mensual_str = input.string('Dotted', '', options = ['Solid', 'Dashed', 'Dotted'], group = group_mensual, inline = 'mensual')
// Trimestral
color_trimestral = input.color(color.new(color.blue, 70), 'Trimestral', group = group_mensual, inline = 'trimestral')
grosor_trimestral = input.int(1, '', minval = 1, maxval = 5, group = group_mensual, inline = 'trimestral')
estilo_trimestral_str = input.string('Solid', '', options = ['Solid', 'Dashed', 'Dotted'], group = group_mensual, inline = 'trimestral')


// --- LÓGICA DE CÁLCULO Y DIBUJO ---

// Función para convertir la opción de estilo (string) a un valor de estilo de línea
f_obtener_estilo(estilo_string) =>
    switch estilo_string
        'Solid' => line.style_solid
        'Dashed' => line.style_dashed
        => line.style_dotted

// Detección de cambios de período.
bool es_nuevo_dia_intradia = dayofmonth(time, gmt_zona_horaria) != dayofmonth(time[1], gmt_zona_horaria)
// LÓGICA ROBUSTA PARA NUEVO MES: Se detecta cuando el día del mes se resetea (ej. 31 -> 1). Inmune a fines de semana.
bool es_nuevo_mes_diario = dayofmonth < dayofmonth[1]
bool es_nuevo_mes_intradia = month(time, gmt_zona_horaria) != month(time[1], gmt_zona_horaria)


// Variables booleanas para detectar el timeframe actual.
bool tf_is_intraday = timeframe.isintraday
bool tf_is_daily_or_weekly = timeframe.isdaily or timeframe.isweekly
bool tf_is_monthly = timeframe.ismonthly
bool tf_is_below_4h = timeframe.in_seconds() < 3600 * 4


// --- DIBUJO CONDICIONAL BASADO EN TIMEFRAME ---

// --- Lógica para Timeframes Intradiarios (SIN CAMBIOS EN LÍNEAS DIARIAS) ---
if tf_is_intraday
    // Dibujo de separadores diarios usando la lógica de GMT
    if es_nuevo_dia_intradia
        dia_semana = dayofweek(time, gmt_zona_horaria)
        es_dia_laboral_intermedio = dia_semana >= dayofweek.tuesday and dia_semana <= dayofweek.saturday

        if dia_semana == dayofweek.monday
            line.new(bar_index, low, bar_index, high, extend = extend.both, color = color_lunes, style = f_obtener_estilo(estilo_lunes_str), width = grosor_lunes)
        if es_dia_laboral_intermedio and tf_is_below_4h
            line.new(bar_index, low, bar_index, high, extend = extend.both, color = color_otros, style = f_obtener_estilo(estilo_otros_str), width = grosor_otros)
        if dia_semana == dayofweek.sunday and show_domingos
            line.new(bar_index, low, bar_index, high, extend = extend.both, color = color_otros, style = f_obtener_estilo(estilo_otros_str), width = grosor_otros)

    // Dibujo opcional de separadores mayores en intradía usando TIMESTAMPS
    if show_mensual_en_intradia and es_nuevo_mes_intradia
        // Calcular el timestamp exacto del inicio del mes en la zona horaria del usuario
        int ts = timestamp(gmt_zona_horaria, year(time, gmt_zona_horaria), month(time, gmt_zona_horaria), 1, 0, 0)

        mes = month(time, gmt_zona_horaria)
        bool es_trimestre = mes == 3 or mes == 6 or mes == 9 or mes == 12
        bool es_mes_intermedio = mes == 1 or mes == 2 or mes == 4 or mes == 5 or mes == 7 or mes == 8 or mes == 10 or mes == 11

        if es_trimestre
            line.new(ts, low, ts, high, xloc.bar_time, extend.both, color_trimestral, f_obtener_estilo(estilo_trimestral_str), grosor_trimestral)
        else if es_mes_intermedio and not show_solo_trimestres
            line.new(ts, low, ts, high, xloc.bar_time, extend.both, color_mensual, f_obtener_estilo(estilo_mensual_str), grosor_mensual)


// --- Lógica para Timeframes Diario, Semanal y Mensual (USANDO TIMESTAMPS) ---
if tf_is_daily_or_weekly or tf_is_monthly
    if es_nuevo_mes_diario
        // Calcular el timestamp exacto del inicio del mes. Usamos la TZ del símbolo para alinear con las velas del gráfico.
        int ts = timestamp(syminfo.timezone, year(time), month(time), 1, 0, 0)

        mes_actual = month(time)
        bool es_trimestre = mes_actual == 3 or mes_actual == 6 or mes_actual == 9 or mes_actual == 12
        bool es_mes_intermedio = mes_actual == 1 or mes_actual == 2 or mes_actual == 4 or mes_actual == 5 or mes_actual == 7 or mes_actual == 8 or mes_actual == 10 or mes_actual == 11

        if es_trimestre
            line.new(ts, low, ts, high, xloc.bar_time, extend.both, color_trimestral, f_obtener_estilo(estilo_trimestral_str), grosor_trimestral)
        else if es_mes_intermedio
            if not show_solo_trimestres and not tf_is_monthly
                line.new(ts, low, ts, high, xloc.bar_time, extend.both, color_mensual, f_obtener_estilo(estilo_mensual_str), grosor_mensual)
